# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Local dev: use your cloudflared HTTPS URL
# Railway: use your Railway public URL or custom domain
APP_URL=https://your-app-url.example.com

PORT=3000
NODE_ENV=development

# Optional: Railway Postgres connection string
DATABASE_URL=
